{
  "name": "json-formatter-tauri",
  "private": true,
  "version": "0.1.19",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "version:sync": "node scripts/auto-version.js  --build",
    "version:set": "node scripts/auto-version.js",
    "version:show": "node scripts/auto-version.js",
    "release:patch": "node scripts/auto-version.js $(node -e \"const pkg=require('./package.json'); const [major,minor,patch]=pkg.version.split('.'); console.log(major+'.'+minor+'.'+(parseInt(patch)+1))\")",
    "release:minor": "node scripts/auto-version.js $(node -e \"const pkg=require('./package.json'); const [major,minor]=pkg.version.split('.'); console.log(major+'.'+(parseInt(minor)+1)+'.0')\")",
    "release:major": "node scripts/auto-version.js $(node -e \"const pkg=require('./package.json'); const [major]=pkg.version.split('.'); console.log((parseInt(major)+1)+'.0.0')\")",
    "test:unit": "jest --passWithNoTests",
    "test:unit:watch": "jest --watch",
    "test:unit:coverage": "jest --coverage",
    "test:e2e": "wdio run wdio.conf.mjs",
    "test:all": "pnpm test:unit && pnpm test:e2e"
  },
  "dependencies": {
    "@tauri-apps/api": "2.9.1",
    "@tauri-apps/plugin-autostart": "~2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "~2.3.2",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-updater": "~2.9.0",
    "@tauri-apps/plugin-window-state": "~2.4.1",
    "@types/jquery": "~3.5.33",
    "jquery": "~3.7.1",
    "katex": "^0.16.28",
    "layui": "^2.13.3",
    "layui-theme-dark": "^2.10.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "~2.9.0",
    "@types/jest": "29.5.12",
    "@types/katex": "^0.16.8",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "playwright": "^1.59.1",
    "ts-jest": "29.1.5",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "webdriverio": "^9.27.0"
  }
}